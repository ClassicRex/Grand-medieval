<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grand Medieval — Community Hub</title>
<link href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-dark: #8b6914;
    --parchment: #f5edd8;
    --parchment-dark: #e8d9b8;
    --ink: #1c1410;
    --ink-mid: #3d2f1e;
    --ink-light: #6b5040;
    --stone: #2a2318;
    --stone-mid: #3d3426;
    --stone-light: #5a4f3a;
    --crimson: #8b1a1a;
    --crimson-light: #b52222;
    --shadow: rgba(0,0,0,0.5);
  }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--stone);
    color: var(--parchment);
    font-family: 'Crimson Text', Georgia, serif;
    font-size: 17px;
    line-height: 1.7;
    min-height: 100vh;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 79px, rgba(0,0,0,0.08) 79px, rgba(0,0,0,0.08) 80px),
      repeating-linear-gradient(90deg, transparent, transparent 79px, rgba(0,0,0,0.05) 79px, rgba(0,0,0,0.05) 80px);
  }

  /* NAV */
  nav {
    background: linear-gradient(to bottom, #0d0b08, var(--stone));
    border-bottom: 2px solid var(--gold-dark);
    padding: 0.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-family: 'Cinzel', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 2px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo::before {
    content: '⚔';
    font-size: 18px;
    color: var(--gold-light);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--parchment-dark);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold); }

  /* HERO */
  .hero {
    position: relative;
    padding: 5rem 2rem 4rem;
    text-align: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.15) 0%, transparent 70%);
  }

  .hero-crest {
    font-size: 56px;
    margin-bottom: 1rem;
    display: block;
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(36px, 7vw, 72px);
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 4px;
    line-height: 1.1;
    text-shadow: 0 2px 20px rgba(201,168,76,0.4), 0 0 60px rgba(201,168,76,0.15);
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 5px;
    color: var(--gold-dark);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-size: 19px;
    font-style: italic;
    color: var(--parchment-dark);
    max-width: 580px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto;
    max-width: 400px;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-dark), transparent);
  }

  .divider-gem {
    width: 10px;
    height: 10px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .badge-row {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .badge {
    padding: 6px 16px;
    border: 1px solid var(--gold-dark);
    border-radius: 2px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--gold-light);
    background: rgba(201,168,76,0.08);
  }

  /* SECTIONS */
  .section {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    display: block;
    margin-top: 6px;
    height: 2px;
    width: 100%;
    background: linear-gradient(to right, var(--gold-dark), transparent);
  }

  .section-intro {
    color: var(--parchment-dark);
    font-style: italic;
    margin-bottom: 2rem;
    font-size: 16px;
  }

  /* MODS */
  .mod-categories {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .mod-category {
    background: var(--stone-mid);
    border: 1px solid var(--stone-light);
    border-top: 2px solid var(--gold-dark);
    border-radius: 2px;
    padding: 1.25rem;
  }

  .mod-category-title {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mod-category-title span {
    font-size: 16px;
  }

  .mod-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .mod-list li {
    font-size: 14px;
    color: var(--parchment-dark);
    padding: 4px 0;
    border-bottom: 1px solid rgba(90,79,58,0.4);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mod-list li::before {
    content: '▸';
    color: var(--gold-dark);
    font-size: 12px;
    flex-shrink: 0;
  }

  .mod-list li:last-child { border-bottom: none; }

  /* FORM */
  .form-wrap {
    background: var(--stone-mid);
    border: 1px solid var(--stone-light);
    border-top: 3px solid var(--gold);
    border-radius: 2px;
    padding: 2rem;
    margin-bottom: 2.5rem;
  }

  .field-group {
    margin-bottom: 1.25rem;
  }

  .field-group label {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 8px;
  }

  .field-group input,
  .field-group textarea,
  .field-group select {
    width: 100%;
    background: var(--stone);
    border: 1px solid var(--stone-light);
    border-radius: 2px;
    padding: 10px 14px;
    color: var(--parchment);
    font-family: 'Crimson Text', serif;
    font-size: 16px;
    outline: none;
    transition: border-color 0.2s;
  }

  .field-group input:focus,
  .field-group textarea:focus,
  .field-group select:focus {
    border-color: var(--gold-dark);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
  }

  .field-group textarea { height: 110px; resize: vertical; }

  .field-group input::placeholder,
  .field-group textarea::placeholder {
    color: var(--stone-light);
    font-style: italic;
  }

  .star-row {
    display: flex;
    gap: 8px;
    margin-bottom: 1.25rem;
  }

  .star {
    font-size: 28px;
    cursor: pointer;
    color: var(--stone-light);
    transition: color 0.1s, transform 0.1s;
    line-height: 1;
  }

  .star.lit { color: var(--gold); }
  .star:hover { transform: scale(1.2); color: var(--gold-light); }

  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1.25rem;
  }

  .tag {
    padding: 5px 14px;
    border: 1px solid var(--stone-light);
    border-radius: 2px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 1px;
    cursor: pointer;
    color: var(--parchment-dark);
    transition: all 0.15s;
  }

  .tag.selected {
    border-color: var(--gold);
    background: rgba(201,168,76,0.15);
    color: var(--gold-light);
  }

  .submit-btn {
    padding: 12px 32px;
    background: transparent;
    border: 2px solid var(--gold);
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.2s;
    width: 100%;
  }

  .submit-btn:hover {
    background: var(--gold);
    color: var(--stone);
  }

  .submit-btn:active { transform: scale(0.99); }

  .success-msg {
    display: none;
    text-align: center;
    padding: 0.75rem;
    margin-top: 1rem;
    background: rgba(139,26,26,0.2);
    border: 1px solid var(--crimson);
    border-radius: 2px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 1px;
    color: #d47c7c;
  }

  /* WALL */
  .reviews-grid {
    display: grid;
    gap: 1rem;
  }

  .review-card {
    background: var(--stone-mid);
    border: 1px solid var(--stone-light);
    border-left: 3px solid var(--gold-dark);
    border-radius: 2px;
    padding: 1.25rem 1.5rem;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .review-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 0.75rem;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 2px;
    background: var(--stone);
    border: 1px solid var(--gold-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--gold);
    flex-shrink: 0;
  }

  .review-meta { flex: 1; }

  .review-name {
    font-family: 'Cinzel', serif;
    font-size: 15px;
    color: var(--gold-light);
    font-weight: 600;
  }

  .review-stars {
    font-size: 14px;
    color: var(--gold);
    letter-spacing: 2px;
  }

  .review-text {
    font-size: 16px;
    font-style: italic;
    color: var(--parchment-dark);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .review-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .review-tag {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1px;
    padding: 3px 10px;
    background: rgba(201,168,76,0.1);
    border: 1px solid var(--gold-dark);
    border-radius: 2px;
    color: var(--gold-dark);
    text-transform: uppercase;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--stone-light);
    text-align: center;
    padding: 2rem;
    margin-top: 3rem;
  }

  footer p {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--stone-light);
  }

  footer a {
    color: var(--gold-dark);
    text-decoration: none;
  }

  footer a:hover { color: var(--gold); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--stone); }
  ::-webkit-scrollbar-thumb { background: var(--stone-light); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--gold-dark); }
</style>
</head>
