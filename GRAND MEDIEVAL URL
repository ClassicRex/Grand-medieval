<script>
  let rating = 0;
  let selectedTags = [];



  function initStars() {
    document.querySelectorAll('.star').forEach(s => {
      s.addEventListener('mouseover', () => lightStars(+s.dataset.v));
      s.addEventListener('mouseleave', () => lightStars(rating));
      s.addEventListener('click', () => { rating = +s.dataset.v; lightStars(rating); });
    });
  }

  function lightStars(n) {
    document.querySelectorAll('.star').forEach(s => {
      s.classList.toggle('lit', +s.dataset.v <= n);
    });
  }

  function initTags() {
    document.querySelectorAll('#area-tags .tag').forEach(t => {
      t.addEventListener('click', () => {
        const tag = t.dataset.tag;
        if (selectedTags.includes(tag)) {
          selectedTags = selectedTags.filter(x => x !== tag);
          t.classList.remove('selected');
        } else {
          selectedTags.push(tag);
          t.classList.add('selected');
        }
      });
    });
  }

  function submitReview() {
    const name = document.getElementById('username').value.trim();
    const text = document.getElementById('review-text').value.trim();
    const version = document.getElementById('version').value || 'Not specified';
    if (!name) { document.getElementById('username').focus(); return; }
    if (!rating) { alert('Please rate the pack with stars!'); return; }
    if (!text) { document.getElementById('review-text').focus(); return; }

    const stars = '⭐'.repeat(rating);
    const tagsText = selectedTags.length ? selectedTags.join(', ') : 'None selected';

    const webhookURL = 'https://discord.com/api/webhooks/1490111336980545548/FMDjsgHEPtiv8n5GhgUpBGVXfyQvresYUPQPyPpaYfinw7GH2bUyvRsmFuXmcwvs5zUl';

    const payload = {
      embeds: [{
        title: '🏰 New Review — Grand Medieval',
        color: 0xc9a84c,
        fields: [
          { name: '👤 Player', value: name, inline: true },
          { name: '⭐ Rating', value: stars, inline: true },
          { name: '🎮 Version', value: version, inline: true },
          { name: '🏷 Areas', value: tagsText, inline: false },
          { name: '📜 Review', value: text, inline: false },
        ],
        footer: { text: 'Grand Medieval Community Hub' },
        timestamp: new Date().toISOString()
      }]
    };

    fetch(webhookURL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    document.getElementById('username').value = '';
    document.getElementById('review-text').value = '';
    document.getElementById('version').selectedIndex = 0;
    rating = 0;
    selectedTags = [];
    lightStars(0);
    document.querySelectorAll('#area-tags .tag').forEach(t => t.classList.remove('selected'));

    const msg = document.getElementById('success');
    msg.style.display = 'block';
    setTimeout(() => msg.style.display = 'none', 4000);
  }

  initStars();
  initTags();
</script>

</body>
</html>
